{
  "name": "semi-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A lightweight command center dashboard for Semi and Kosta.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "sync:data": "node scripts/sync-dashboard-data.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --pretty false"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
